---
const links = [
    { href: "/categorias/camisetas", label: "Camisetas" },
    { href: "/categorias/gorras", label: "Gorras" },
    { href: "/categorias/busos", label: "Busos" },
    { href: "/categorias/carrieles", label: "Carrieles" },
    { href: "/categorias/supreme", label: "Supreme" },
];
---

<header
    class="fixed top-0 left-0 w-full z-50 backdrop-blur-md bg-white/10 border-b border-white/20"
>
    <nav
        class="max-w-6xl mx-auto relative flex items-center justify-between px-6 py-4"
    >
        <!-- Botón hamburguesa: solo en mobile -->
        <button
            id="menu-toggle"
            aria-label="Abrir menú"
            aria-expanded="false"
            class="md:hidden relative h-6 w-6 text-white"
        >
            <svg
                id="icon-open"
                xmlns="http://www.w3.org/2000/svg"
                class="absolute inset-0 h-6 w-6 transition-opacity duration-300"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
            <svg
                id="icon-close"
                xmlns="http://www.w3.org/2000/svg"
                class="absolute inset-0 h-6 w-6 opacity-0 transition-opacity duration-300"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>

        <!-- Izquierda: categorías, pegadas al borde (solo desktop) -->
        <ul class="hidden md:flex gap-6 text-white/90 font-medium">
            {
                links.map((link) => (
                    <li>
                        <a
                            href={link.href}
                            class="hover:text-white transition-colors"
                        >
                            {link.label}
                        </a>
                    </li>
                ))
            }
        </ul>

        <!-- Centro: logo -->
        <a href="/" class="absolute left-1/2 -translate-x-1/2">
            <div class="relative h-8 w-32 flex items-center justify-center">
                <span
                    id="logo-text"
                    class="absolute inset-0 flex items-center justify-center text-xl font-bold text-white tracking-wide transition-opacity duration-500"
                >
                    STORE 21
                </span>
                <img
                    id="logo-image"
                    src="/logo.png"
                    alt="Store 21"
                    class="absolute inset-0 m-auto h-8 w-auto opacity-0 transition-opacity duration-500"
                />
            </div>
        </a>

        <!-- Derecha: búsqueda -->
        <button
            id="search-toggle"
            aria-label="Buscar"
            class="text-white hover:text-white/70 transition-colors"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M21 21l-4.35-4.35M17 11a6 6 0 11-12 0 6 6 0 0112 0z"
                ></path>
            </svg>
        </button>
    </nav>

    <!-- Panel mobile -->
    <div
        id="mobile-menu"
        class="hidden md:hidden border-t border-white/20 bg-black/80 backdrop-blur-md"
    >
        <ul class="flex flex-col divide-y divide-white/10">
            {
                links.map((link) => (
                    <li>
                        <a
                            href={link.href}
                            class="block px-6 py-4 text-white/90 hover:text-white hover:bg-white/5 transition-colors"
                        >
                            {link.label}
                        </a>
                    </li>
                ))
            }
        </ul>
    </div>

    <dialog
        id="search-dialog"
        class="m-auto backdrop:bg-black/80 bg-transparent p-0 w-full max-w-lg"
    >
        <div class="bg-black border border-white/20 rounded-xl p-4">
            <div class="flex items-center gap-2 border-b border-white/20 pb-3">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-5 w-5 text-white/50"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M21 21l-4.35-4.35M17 11a6 6 0 11-12 0 6 6 0 0112 0z"
                    ></path>
                </svg>
                <input
                    id="search-input"
                    type="text"
                    placeholder="Buscar productos..."
                    autocomplete="off"
                    class="w-full bg-transparent text-white placeholder-white/40 focus:outline-none"
                />
                <button
                    id="search-close"
                    aria-label="Cerrar"
                    class="text-white/50 hover:text-white text-xl leading-none"
                    >&times;</button
                >
            </div>
            <ul
                id="search-results"
                class="mt-3 max-h-80 overflow-y-auto divide-y divide-white/10"
            >
            </ul>
        </div>
    </dialog>
</header>

<script>
    const logoText = document.getElementById("logo-text");
    const logoImage = document.getElementById("logo-image");
    const threshold = 80;

    function updateLogo() {
        const scrolled = window.scrollY > threshold;
        logoText?.classList.toggle("opacity-0", scrolled);
        logoImage?.classList.toggle("opacity-0", !scrolled);
    }

    window.addEventListener("scroll", updateLogo);
    updateLogo();

    const menuToggle = document.getElementById("menu-toggle");
    const mobileMenu = document.getElementById("mobile-menu");
    const iconOpen = document.getElementById("icon-open");
    const iconClose = document.getElementById("icon-close");

    menuToggle?.addEventListener("click", () => {
        const isNowHidden = mobileMenu?.classList.toggle("hidden");
        const isOpen = !isNowHidden;
        menuToggle.setAttribute("aria-expanded", String(isOpen));
        iconOpen?.classList.toggle("opacity-0", isOpen);
        iconClose?.classList.toggle("opacity-0", !isOpen);
    });

    const searchToggle = document.getElementById("search-toggle");
    const searchDialog = document.getElementById(
        "search-dialog",
    ) as HTMLDialogElement;
    const searchClose = document.getElementById("search-close");
    const searchInput = document.getElementById(
        "search-input",
    ) as HTMLInputElement;
    const searchResults = document.getElementById("search-results");

    searchToggle?.addEventListener("click", () => {
        searchDialog?.showModal();
        searchInput?.focus();
    });

    searchClose?.addEventListener("click", () => searchDialog?.close());
    searchDialog?.addEventListener("click", (event) => {
        if (event.target === searchDialog) searchDialog.close();
    });

    let debounceTimer: ReturnType<typeof setTimeout>;

    searchInput?.addEventListener("input", () => {
        clearTimeout(debounceTimer);
        const query = searchInput.value.trim();

        if (query.length < 2) {
            if (searchResults) searchResults.innerHTML = "";
            return;
        }

        debounceTimer = setTimeout(async () => {
            const response = await fetch(
                `/api/search?q=${encodeURIComponent(query)}`,
            );
            const products = await response.json();

            if (!searchResults) return;

            if (products.length === 0) {
                searchResults.innerHTML = `<li class="py-4 text-center text-white/50 text-sm">Sin resultados</li>`;
                return;
            }

            const formatPrice = (value: number) =>
                new Intl.NumberFormat("es-CO", {
                    style: "currency",
                    currency: "COP",
                    maximumFractionDigits: 0,
                }).format(value);

            searchResults.innerHTML = products
                .map(
                    (product: any) => `
            <li>
              <a href="/productos/${product.id}" class="flex items-center gap-3 py-3 px-2 hover:bg-white/5 rounded-lg transition-colors">
                <img src="${product.image_urls[0]}" alt="${product.name}" class="h-12 w-12 object-cover rounded-md" />
                <div>
                  <p class="text-white text-sm font-medium">${product.name}</p>
                  <p class="text-white/50 text-xs">${formatPrice(product.price)}</p>
                </div>
              </a>
            </li>
          `,
                )
                .join("");
        }, 300);
    });
</script>
