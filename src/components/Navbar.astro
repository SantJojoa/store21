---
const links = [
    { href: "/categorias/camisetas", label: "Camisetas" },
    { href: "/categorias/gorras", label: "Gorras" },
    { href: "/categorias/busos", label: "Busos" },
    { href: "/categorias/carrieles", label: "Carrieles" },
    { href: "/categorias/supreme", label: "Supreme" },
];
---

<header
    class="fixed top-0 left-0 w-full z-50 backdrop-blur-md bg-white/10 border-b border-white/20"
>
    <nav
        class="max-w-6xl mx-auto relative flex items-center justify-between px-6 py-4"
    >
        <!-- Botón hamburguesa: solo en mobile -->
        <button
            id="menu-toggle"
            aria-label="Abrir menú"
            aria-expanded="false"
            class="md:hidden relative h-6 w-6 text-white"
        >
            <svg
                id="icon-open"
                xmlns="http://www.w3.org/2000/svg"
                class="absolute inset-0 h-6 w-6 transition-opacity duration-300"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
            <svg
                id="icon-close"
                xmlns="http://www.w3.org/2000/svg"
                class="absolute inset-0 h-6 w-6 opacity-0 transition-opacity duration-300"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>

        <!-- Izquierda: categorías, pegadas al borde (solo desktop) -->
        <ul class="hidden md:flex gap-6 text-white/90 font-medium">
            {
                links.map((link) => (
                    <li>
                        <a
                            href={link.href}
                            class="hover:text-white transition-colors"
                        >
                            {link.label}
                        </a>
                    </li>
                ))
            }
        </ul>

        <!-- Centro: logo -->
        <a href="/" class="absolute left-1/2 -translate-x-1/2">
            <div class="relative h-8 w-32 flex items-center justify-center">
                <span
                    id="logo-text"
                    class="absolute inset-0 flex items-center justify-center text-xl font-bold text-white tracking-wide transition-opacity duration-500"
                >
                    STORE 21
                </span>
                <img
                    id="logo-image"
                    src="/logo.png"
                    alt="Store 21"
                    class="absolute inset-0 m-auto h-8 w-auto opacity-0 transition-opacity duration-500"
                />
            </div>
        </a>

        <!-- Derecha: búsqueda -->
        <div class="flex items-center gap-4">
            <button
                id="search-toggle"
                aria-label="Buscar"
                class="text-white hover:text-white/70 transition-colors"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-5 w-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M21 21l-4.35-4.35M17 11a6 6 0 11-12 0 6 6 0 0112 0z"
                    ></path>
                </svg>
            </button>

            <div class="relative">
                <button
                    id="cart-toggle"
                    aria-label="Carrito"
                    class="text-white hover:text-white/70 transition-colors"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-5 w-5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="1.5"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25c-.67 0-1.189-.578-1.119-1.243l1.263-12A1.125 1.125 0 015.513 9h12.974c.576 0 1.059.435 1.119 1.007z"
                        ></path>
                    </svg>
                </button>
                <span
                    id="cart-count"
                    class="hidden absolute -top-2 -right-2 bg-white text-black text-[10px] font-bold h-4 w-4 flex items-center justify-center rounded-full"
                ></span>
            </div>
        </div>
    </nav>

    <!-- Panel mobile -->
    <div
        id="mobile-menu"
        class="hidden md:hidden border-t border-white/20 bg-black/80 backdrop-blur-md"
    >
        <ul class="flex flex-col divide-y divide-white/10">
            {
                links.map((link) => (
                    <li>
                        <a
                            href={link.href}
                            class="block px-6 py-4 text-white/90 hover:text-white hover:bg-white/5 transition-colors"
                        >
                            {link.label}
                        </a>
                    </li>
                ))
            }
        </ul>
    </div>

    <dialog
        id="search-dialog"
        class="m-auto backdrop:bg-black/80 bg-transparent p-0 w-full max-w-lg"
    >
        <div class="bg-black border border-white/20 rounded-xl p-4">
            <div class="flex items-center gap-2 border-b border-white/20 pb-3">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-5 w-5 text-white/50"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M21 21l-4.35-4.35M17 11a6 6 0 11-12 0 6 6 0 0112 0z"
                    ></path>
                </svg>
                <input
                    id="search-input"
                    type="text"
                    placeholder="Buscar productos..."
                    autocomplete="off"
                    class="w-full bg-transparent text-white placeholder-white/40 focus:outline-none"
                />
                <button
                    id="search-close"
                    aria-label="Cerrar"
                    class="text-white/50 hover:text-white text-xl leading-none"
                    >&times;</button
                >
            </div>
            <ul
                id="search-results"
                class="mt-3 max-h-80 overflow-y-auto divide-y divide-white/10"
            >
            </ul>
        </div>
    </dialog>

</header>

<div
    id="cart-backdrop"
    class="fixed inset-0 bg-black/70 z-40 opacity-0 pointer-events-none transition-opacity duration-300"
>
</div>

<aside
    id="cart-panel"
    class="fixed top-0 right-0 z-50 h-full w-full max-w-md bg-black border-l border-white/20 translate-x-full transition-transform duration-300 ease-in-out flex flex-col overflow-hidden"
>
    <div class="flex items-center justify-between border-b border-white/20 px-6 py-4">
        <h2 class="text-lg font-semibold text-white">Tu carrito</h2>
        <button
            id="cart-close"
            aria-label="Cerrar"
            class="text-white/50 hover:text-white text-2xl leading-none"
            >&times;</button
        >
    </div>

    <div class="flex-1 min-h-0 overflow-y-auto px-6 py-4">
        <ul id="cart-items" class="divide-y divide-white/10"></ul>
        <div id="cart-empty" class="py-8 text-center text-white/50 text-sm">
            Tu carrito está vacío
        </div>

        <div class="mt-6 border-t border-white/20 pt-4 pb-2 space-y-3">
            <p class="text-sm text-white/70">Datos de envío</p>
            <input
                id="shipping-name"
                type="text"
                placeholder="Nombre completo"
                class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-sm text-white placeholder-white/40 focus:outline-none focus:border-white"
            />
            <input
                id="shipping-cc"
                type="text"
                placeholder="Cédula (CC)"
                class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-sm text-white placeholder-white/40 focus:outline-none focus:border-white"
            />
            <input
                id="shipping-phone"
                type="tel"
                placeholder="Celular"
                class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-sm text-white placeholder-white/40 focus:outline-none focus:border-white"
            />
            <input
                id="shipping-address"
                type="text"
                placeholder="Dirección exacta (indica si es oficina)"
                class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-sm text-white placeholder-white/40 focus:outline-none focus:border-white"
            />
            <input
                id="shipping-city"
                type="text"
                placeholder="Ciudad"
                class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-sm text-white placeholder-white/40 focus:outline-none focus:border-white"
            />
            <p
                id="shipping-feedback"
                class="text-xs text-red-400 opacity-0 transition-opacity duration-300"
            >
            </p>
        </div>
    </div>

    <div class="border-t border-white/20 px-6 py-4">
        <div class="flex items-center justify-between text-white">
            <span class="text-white/70">Total</span>
            <span id="cart-total" class="text-lg font-semibold">$ 0</span>
        </div>
        <button
            id="cart-checkout"
            class="mt-4 w-full bg-green-500 text-black font-semibold py-4 rounded-full hover:bg-green-400 transition-colors"
        >
            Comprar por WhatsApp
        </button>
    </div>
</aside>

<script>
    const logoText = document.getElementById("logo-text");
    const logoImage = document.getElementById("logo-image");
    const threshold = 80;

    function updateLogo() {
        const scrolled = window.scrollY > threshold;
        logoText?.classList.toggle("opacity-0", scrolled);
        logoImage?.classList.toggle("opacity-0", !scrolled);
    }

    window.addEventListener("scroll", updateLogo);
    updateLogo();

    const menuToggle = document.getElementById("menu-toggle");
    const mobileMenu = document.getElementById("mobile-menu");
    const iconOpen = document.getElementById("icon-open");
    const iconClose = document.getElementById("icon-close");

    menuToggle?.addEventListener("click", () => {
        const isNowHidden = mobileMenu?.classList.toggle("hidden");
        const isOpen = !isNowHidden;
        menuToggle.setAttribute("aria-expanded", String(isOpen));
        iconOpen?.classList.toggle("opacity-0", isOpen);
        iconClose?.classList.toggle("opacity-0", !isOpen);
    });

    const searchToggle = document.getElementById("search-toggle");
    const searchDialog = document.getElementById(
        "search-dialog",
    ) as HTMLDialogElement;
    const searchClose = document.getElementById("search-close");
    const searchInput = document.getElementById(
        "search-input",
    ) as HTMLInputElement;
    const searchResults = document.getElementById("search-results");

    searchToggle?.addEventListener("click", () => {
        searchDialog?.showModal();
        searchInput?.focus();
    });

    searchClose?.addEventListener("click", () => searchDialog?.close());
    searchDialog?.addEventListener("click", (event) => {
        if (event.target === searchDialog) searchDialog.close();
    });

    let debounceTimer: ReturnType<typeof setTimeout>;

    searchInput?.addEventListener("input", () => {
        clearTimeout(debounceTimer);
        const query = searchInput.value.trim();

        if (query.length < 2) {
            if (searchResults) searchResults.innerHTML = "";
            return;
        }

        debounceTimer = setTimeout(async () => {
            const response = await fetch(
                `/api/search?q=${encodeURIComponent(query)}`,
            );
            const products = await response.json();

            if (!searchResults) return;

            if (products.length === 0) {
                searchResults.innerHTML = `<li class="py-4 text-center text-white/50 text-sm">Sin resultados</li>`;
                return;
            }

            const formatPrice = (value: number) =>
                new Intl.NumberFormat("es-CO", {
                    style: "currency",
                    currency: "COP",
                    maximumFractionDigits: 0,
                }).format(value);

            searchResults.innerHTML = products
                .map(
                    (product: any) => `
            <li>
              <a href="/productos/${product.id}" class="flex items-center gap-3 py-3 px-2 hover:bg-white/5 rounded-lg transition-colors">
                <img
                    src="${product.image_urls[0]}"
                    alt="${product.name}"
                    class="h-12 w-12 object-cover rounded-md"
                />      
                <div>
                  <p class="text-white text-sm font-medium">${product.name}</p>
                  <p class="text-white/50 text-xs">${formatPrice(product.price)}</p>
                </div>
              </a>
            </li>
          `,
                )
                .join("");
        }, 300);
    });

    import {
        getCart,
        removeFromCart,
        updateQuantity,
        getCartTotal,
        clearCart,
    } from "../lib/cart";

    const WHATSAPP_NUMBER = "3177727247"; // ej: "573001234567" (indicativo + número, sin +)

    const cartToggle = document.getElementById("cart-toggle");
    const cartPanel = document.getElementById("cart-panel");
    const cartBackdrop = document.getElementById("cart-backdrop");
    const cartClose = document.getElementById("cart-close");
    const cartItemsList = document.getElementById("cart-items");
    const cartEmpty = document.getElementById("cart-empty");
    const cartTotal = document.getElementById("cart-total");
    const cartCount = document.getElementById("cart-count");
    const cartCheckout = document.getElementById("cart-checkout");

    const shippingName = document.getElementById(
        "shipping-name",
    ) as HTMLInputElement;
    const shippingCC = document.getElementById(
        "shipping-cc",
    ) as HTMLInputElement;
    const shippingPhone = document.getElementById(
        "shipping-phone",
    ) as HTMLInputElement;
    const shippingAddress = document.getElementById(
        "shipping-address",
    ) as HTMLInputElement;
    const shippingCity = document.getElementById(
        "shipping-city",
    ) as HTMLInputElement;
    const shippingFeedback = document.getElementById("shipping-feedback");

    const formatPrice = (value: number) =>
        new Intl.NumberFormat("es-CO", {
            style: "currency",
            currency: "COP",
            maximumFractionDigits: 0,
        }).format(value);

    function renderCart() {
        const cart = getCart();

        if (cartCount) {
            const totalItems = cart.reduce(
                (sum, item) => sum + item.quantity,
                0,
            );
            if (totalItems > 0) {
                cartCount.textContent = String(totalItems);
                cartCount.classList.remove("hidden");
            } else {
                cartCount.classList.add("hidden");
            }
        }

        if (!cartItemsList || !cartEmpty || !cartTotal) return;

        if (cart.length === 0) {
            cartItemsList.innerHTML = "";
            cartEmpty.classList.remove("hidden");
            cartTotal.textContent = formatPrice(0);
            return;
        }

        cartEmpty.classList.add("hidden");

        cartItemsList.innerHTML = cart
            .map(
                (item, index) => `
        <li class="flex items-center gap-3 py-3">
          <img src="${item.imageUrl}" alt="${item.name}" class="h-14 w-14 object-cover rounded-md" />
          <div class="flex-1">
            <p class="text-sm font-medium">${item.name}</p>
            <p class="text-xs text-white/50">Talla ${item.size} · ${formatPrice(item.price)}</p>
            <div class="mt-1 flex items-center gap-2">
              <button data-action="decrease" data-index="${index}" class="h-6 w-6 border border-white/30 rounded text-xs">-</button>
              <span class="text-xs w-4 text-center">${item.quantity}</span>
              <button data-action="increase" data-index="${index}" class="h-6 w-6 border border-white/30 rounded text-xs">+</button>
            </div>
          </div>
          <button data-action="remove" data-index="${index}" class="text-white/40 hover:text-white text-sm">Quitar</button>
        </li>
      `,
            )
            .join("");

        cartTotal.textContent = formatPrice(getCartTotal(cart));
    }

    function openCart() {
        renderCart();
        cartBackdrop?.classList.remove("opacity-0", "pointer-events-none");
        cartPanel?.classList.remove("translate-x-full");
        document.body.classList.add("overflow-hidden");
    }

    function closeCart() {
        cartPanel?.classList.add("translate-x-full");
        cartBackdrop?.classList.add("opacity-0", "pointer-events-none");
        document.body.classList.remove("overflow-hidden");
    }

    cartToggle?.addEventListener("click", openCart);
    cartClose?.addEventListener("click", closeCart);
    cartBackdrop?.addEventListener("click", closeCart);

    document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") closeCart();
    });

    cartItemsList?.addEventListener("click", (event) => {
        const target = event.target as HTMLElement;
        const action = target.dataset.action;
        const index = target.dataset.index
            ? Number(target.dataset.index)
            : null;
        if (index === null) return;

        const cart = getCart();

        if (action === "remove") {
            removeFromCart(index);
        } else if (action === "increase") {
            updateQuantity(index, cart[index].quantity + 1);
        } else if (action === "decrease") {
            updateQuantity(index, cart[index].quantity - 1);
        }

        renderCart();
    });

    cartCheckout?.addEventListener("click", () => {
        const cart = getCart();
        if (cart.length === 0) return;

        const name = shippingName.value.trim();
        const cc = shippingCC.value.trim();
        const phone = shippingPhone.value.trim();
        const address = shippingAddress.value.trim();
        const city = shippingCity.value.trim();

        if (!name || !cc || !phone || !address || !city) {
            if (shippingFeedback) {
                shippingFeedback.textContent =
                    "Completa todos los datos de envío";
                shippingFeedback.classList.remove("opacity-0");
            }
            return;
        }

        const lines = cart.map(
            (item) =>
                `- ${item.name} (Talla ${item.size}) x${item.quantity} - ${formatPrice(item.price * item.quantity)}`,
        );

        const message = [
            "Te hablo desde la pagina web",
            "Quiero comprar",
            "",
            ...lines,
            "",
            `Total: ${formatPrice(getCartTotal(cart))}`,
            "",
            "Déjame datos de envío📦🇨🇴",
            `🫵🏼Nombre: ${name}`,
            `🪪CC: ${cc}`,
            `📲Cel: ${phone}`,
            `📍Dirección exacta (Poner si es oficina): ${address}`,
            `🏙️Ciudad: ${city}`,
        ].join("\n");

        const whatsappUrl = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(message)}`;
        window.open(whatsappUrl, "_blank");

        clearCart();
        shippingName.value = "";
        shippingCC.value = "";
        shippingPhone.value = "";
        shippingAddress.value = "";
        shippingCity.value = "";
        closeCart();
    });

    window.addEventListener("cart:updated", renderCart);
    renderCart();
</script>
